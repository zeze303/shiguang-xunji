@import "../styles/theme-tokens.wxss";
@import "../styles/icon-placeholder.wxss";

.dock-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  padding: 0 28rpx calc(24rpx + env(safe-area-inset-bottom));
  pointer-events: none;
  background: transparent;
  box-sizing: border-box;
}

.dock {
  pointer-events: auto;
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  min-height: 124rpx;
  padding: 14rpx 12rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(15, 23, 42, 0.09);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.16);
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.theme-root.theme-dark .dock {
  background: rgba(15, 23, 42, 0.88);
  border-color: rgba(255, 255, 255, 0.12);
  box-shadow: 0 20rpx 52rpx rgba(0, 0, 0, 0.38);
}

/* 轻微磨砂：低端机若卡顿可整段注释 */
.dock {
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 4rpx 4rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--cyan);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.theme-root.theme-dark .tab-item::after {
  background: #22d3ee;
}

.tab-item--active::after {
  opacity: 1;
}

.tab-orbit {
  position: absolute;
  inset: 8rpx 10rpx;
  border-radius: 18rpx;
  opacity: 0;
  background: linear-gradient(145deg, rgba(8, 145, 178, 0.12), rgba(99, 102, 241, 0.18));
  transition: opacity 0.3s ease;
}

.theme-root.theme-dark .tab-orbit {
  background: linear-gradient(145deg, rgba(34, 211, 238, 0.12), rgba(99, 102, 241, 0.18));
}

.tab-item--active .tab-orbit {
  opacity: 1;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 6rpx;
  opacity: 0.72;
  position: relative;
  z-index: 1;
  transition: opacity 0.3s ease, filter 0.3s ease;
}

.tab-icon--active {
  opacity: 1;
  filter: drop-shadow(0 0 14rpx rgba(8, 145, 178, 0.24));
}

.theme-root.theme-dark .tab-icon--active {
  filter: drop-shadow(0 0 16rpx rgba(34, 211, 238, 0.24));
}

.tab-text {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  color: var(--text-dim);
  font-weight: 500;
  transition: color 0.3s ease;
}

.tab-item--active .tab-text {
  color: var(--cyan);
  font-weight: 600;
}

/* T02: 发布按钮放大 + 发光上浮 */
.tab-item--publish .tab-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 4rpx;
  margin-top: -8rpx;
  transition: filter 0.3s ease;
}

.tab-item--publish .tab-icon--active {
  filter: drop-shadow(0 0 20rpx rgba(8, 145, 178, 0.38));
}

.theme-root.theme-dark .tab-item--publish .tab-icon--active {
  filter: drop-shadow(0 0 24rpx rgba(34, 211, 238, 0.38));
}
