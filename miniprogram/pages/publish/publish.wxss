.publish-page {
  padding: 24rpx;
}

.publish-hero {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.publish-hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.24em;
  color: var(--text-dim);
}

.publish-hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.publish-hero-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.8;
}

.tool-notice {
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--color-info-bg);
  color: var(--color-info);
  font-size: var(--font-sm);
  text-align: center;
  line-height: 1.6;
}

.publish-card {
  padding: 24rpx;
}

.section-subtitle {
  margin: -6rpx 0 18rpx;
  font-size: 22rpx;
  color: var(--text-dim);
  line-height: 1.7;
}

.openid-banner {
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
  border: 1rpx solid #fdba74;
}

.openid-banner-loading {
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  border-color: #dbeafe;
  color: #1d4ed8;
  font-size: 26rpx;
}

.page-root.theme-dark .openid-banner-loading {
  background: rgba(59, 130, 246, 0.12);
  border-color: rgba(96, 165, 250, 0.28);
  color: #93c5fd;
}

.openid-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #c2410c;
}

.page-root.theme-dark .openid-banner-title {
  color: #fdba74;
}

.openid-banner-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7c2d12;
  line-height: 1.6;
}

.page-root.theme-dark .openid-banner-desc {
  color: #fed7aa;
}

.openid-banner-action {
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #fdba74;
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 600;
}

.page-root.theme-dark .openid-banner-action {
  background: rgba(15, 23, 42, 0.55);
  border-color: rgba(251, 191, 36, 0.28);
  color: #fdba74;
}

.draft-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  border: 1rpx solid #dbeafe;
}

.draft-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d4ed8;
}

.page-root.theme-dark .draft-banner-title {
  color: #93c5fd;
}

.draft-banner-time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.page-root.theme-dark .draft-banner-time {
  color: #94a3b8;
}

.draft-banner-action {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #dc2626;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fecaca;
}

.page-root.theme-dark .draft-banner-action {
  background: rgba(15, 23, 42, 0.55);
  border-color: rgba(248, 113, 113, 0.28);
  color: #fda4af;
}

.tabs {
  display: flex;
  background: var(--glass);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--glass-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 400;
}

.tab-active {
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  font-weight: 600;
}

.publish-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.publish-input:focus {
  border-color: var(--cyan);
  box-shadow: inset 3rpx 0 0 var(--cyan);
}

.publish-textarea:focus {
  border-color: var(--cyan);
  box-shadow: inset 3rpx 0 0 var(--cyan);
}

.input-error {
  border-color: #ef4444;
  background: #fef2f2;
}

.error-text {
  margin: 0 0 14rpx 8rpx;
  font-size: 22rpx;
  color: #dc2626;
}

.picker-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--text-primary);
}

.picker-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.time-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240rpx, 1fr));
  gap: 16rpx;
}

.time-picker {
  margin-bottom: 0;
}

.contact-box {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
}

.publish-note-card {
  margin-top: 20rpx;
  padding: 24rpx;
  background: rgba(8, 145, 178, 0.08);
  border: 1rpx solid rgba(8, 145, 178, 0.18);
}

.page-root.theme-dark .publish-note-card {
  background: rgba(34, 211, 238, 0.08);
  border-color: rgba(34, 211, 238, 0.18);
}

.publish-note-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--cyan);
}

.publish-note-item {
  margin-top: 12rpx;
  color: var(--text-primary);
  font-size: 24rpx;
  line-height: 1.8;
}

.contact-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.publish-textarea {
  min-height: 260rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  line-height: 1.8;
}

.input-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}



.publish-bottom-safe {
  height: 240rpx;
}

.publish-fixed-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(170rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  background: transparent;
  padding: 0;
}

.publish-fixed-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 12rpx;
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  font-weight: 600;
  box-shadow: 0 12rpx 36rpx rgba(8, 145, 178, 0.28);
}

.publish-fixed-btn::after {
  border: none;
}

.publish-fixed-btn-disabled {
  background: var(--surface-muted);
  color: var(--text-dim);
  box-shadow: none;
}

.publish-fixed-btn-success {
  background: var(--color-success);
  color: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(16, 185, 129, 0.28);
}
