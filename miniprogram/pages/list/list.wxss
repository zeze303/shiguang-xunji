.list-page {
  padding-bottom: 150rpx;
}

.list-hero {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.list-hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.24em;
  color: var(--text-dim);
}

.list-hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.list-hero-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
}

.search-box {
  width: 100%;
  margin-bottom: 16rpx;
}

.list-search-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: var(--glass);
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  color: var(--text-primary);
}

.list-placeholder {
  color: var(--text-dim);
  font-size: 28rpx;
}

.tabs {
  display: flex;
  background: var(--glass);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--glass-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 400;
}

.tab-active {
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  font-weight: 600;
}

.cat-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.cat-list {
  display: inline-flex;
  padding-bottom: 4rpx;
}

.cat-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-md);
  margin-right: 10rpx;
  color: var(--text-primary);
  font-size: var(--font-sm);
  border: 1.5rpx solid var(--glass-border);
  background: transparent;
}

.cat-chip-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.cat-chip-active {
  color: var(--cyan);
  border-color: var(--cyan);
  background: rgba(8, 145, 178, 0.06);
  font-weight: 600;
}

.page-root.theme-dark .cat-chip-active {
  border-color: var(--cyan);
  background: rgba(34, 211, 238, 0.06);
}

.status-scroll {
  white-space: nowrap;
  margin-bottom: 22rpx;
}

.status-list {
  display: inline-flex;
  padding-bottom: 4rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  margin-right: 8rpx;
  border-radius: 999rpx;
  color: var(--text-dim);
  font-size: 22rpx;
  border: 1rpx solid transparent;
}

.status-tag-active {
  color: var(--text-primary);
  font-weight: 600;
  border-color: var(--glass-border);
  background: var(--glass);
}

.post-card {
  margin-bottom: 20rpx;
  border-color: rgba(8, 145, 178, 0.12);
}

.post-inner {
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}

.post-cat-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.post-body {
  flex: 1;
  min-width: 0;
}

.page-root.theme-dark .post-card {
  border-color: rgba(34, 211, 238, 0.12);
}

.new-post-card {
  border: 1rpx solid rgba(52, 211, 153, 0.45);
  background: rgba(52, 211, 153, 0.06);
}

.page-root.theme-dark .new-post-card {
  background: rgba(52, 211, 153, 0.08);
}

.post-head {
  align-items: flex-start;
}

.post-head-right {
  display: flex;
  align-items: center;
}

.new-badge {
  margin-right: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.5;
}

.post-meta {
  margin-top: 16rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.6;
}

.dot {
  margin: 0 10rpx;
}

.post-desc {
  margin-top: 14rpx;
  color: var(--text-primary);
  opacity: 0.88;
  font-size: 26rpx;
  line-height: 1.7;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180rpx, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.list-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20rpx;
  background: var(--surface-muted);
  border: 1rpx solid var(--glass-border);
}

.status-row {
  align-items: center;
}

.action-row {
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--glass-border);
}

.btn-detail {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 1.5rpx solid var(--cyan);
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

.status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-warning {
  background: rgba(217, 119, 6, 0.12);
  color: var(--amber);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
}

.status-success {
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.status-default {
  background: var(--surface-muted);
  color: var(--text-dim);
  border: 1rpx solid var(--glass-border);
}

.empty-wrap {
  padding: 100rpx 0;
  text-align: center;
}

.empty-placeholder {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 14rpx;
}

.empty-text {
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 600;
}

.empty-subtext {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.85;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(8, 145, 178, 0.12);
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(8, 145, 178, 0.28);
}

.page-root.theme-dark .empty-action {
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.35);
}
