<view class="page-root {{themeClass}}">
<view class="container page-top-safe list-page">
  <view class="list-hero card">
    <view class="list-hero-kicker">LIVE FILTERS</view>
    <view class="list-hero-title">失物线索台账</view>
    <view class="list-hero-desc">按类型、分类、状态快速筛选，第一时间锁定有效信息。</view>
  </view>

  <view class="search-box">
    <input class="input list-search-input" value="{{keyword}}" placeholder="搜索物品名称、地点、标题" placeholder-class="list-placeholder" bindinput="onInput" />
  </view>

  <view class="tabs">
    <view class="tab-item {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab-item {{activeTab === 'found' ? 'tab-active' : ''}}" data-tab="found" bindtap="switchTab">招领</view>
    <view class="tab-item {{activeTab === 'lost' ? 'tab-active' : ''}}" data-tab="lost" bindtap="switchTab">寻物</view>
  </view>

  <scroll-view scroll-x class="category-scroll" enable-flex="true">
    <view class="category-list">
      <view class="category-chip {{activeCategory === item ? 'category-chip-active' : ''}}" wx:for="{{categories}}" wx:key="*this" data-category="{{item}}" bindtap="switchCategory">
        {{item}}
      </view>
    </view>
  </scroll-view>

  <scroll-view scroll-x class="category-scroll status-scroll" enable-flex="true">
    <view class="category-list">
      <view class="category-chip {{statusFilter === item.key ? 'category-chip-active' : ''}}" wx:for="{{quickFilters}}" wx:key="key" data-status="{{item.key}}" bindtap="switchStatus">
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="card post-card {{item.isNew ? 'new-post-card' : ''}}" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
    <view class="between post-head">
      <view class="post-title">{{item.title}}</view>
      <view class="post-head-right">
        <view wx:if="{{item.isNew}}" class="new-badge">最新</view>
        <view class="tag {{item.type === 'found' ? 'tag-green' : 'tag-orange'}}">{{item.type === 'found' ? '招领' : '寻物'}}</view>
      </view>
    </view>

    <view class="post-meta">
      <text>{{item.category}}</text>
      <text class="dot">·</text>
      <text>{{item.location}}</text>
      <text class="dot">·</text>
      <text>{{item.time}}</text>
    </view>

    <view class="post-desc">{{item.description}}</view>

    <view class="image-grid" wx:if="{{item.images && item.images.length}}">
      <image class="list-image" wx:for="{{item.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
    </view>

    <view class="between mt-20 status-row">
      <view class="text-muted">{{item.userName}}</view>
      <view class="status status-{{item.statusTone}}">{{item.statusText}}</view>
    </view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty-wrap">
    <image class="empty-placeholder" src="/images/icon-empty-placeholder.svg" mode="aspectFit" />
    <view class="empty-text">{{emptyTitle}}</view>
    <view class="empty-subtext">{{emptyDesc}}</view>
    <view wx:if="{{hasFilter}}" class="empty-action" bindtap="resetFilters">重置筛选</view>
  </view>
</view>
</view>
