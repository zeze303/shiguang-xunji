<view class="page-root {{themeClass}}">
<view class="container page-top-safe my-posts-page">
  <view class="my-posts-hero card">
    <view class="my-posts-hero-kicker">MY RECORDS</view>
    <view class="my-posts-hero-title">我的登记记录</view>
    <view class="my-posts-hero-desc">查看审核状态、失败原因、展示进度和最终处理结果。</view>
  </view>

  <view class="search-box">
    <input class="input list-search-input" value="{{keyword}}" placeholder="搜索标题、地点、失败原因" placeholder-class="list-placeholder" bindinput="onInput" />
  </view>

  <scroll-view scroll-x class="filter-scroll" enable-flex="true">
    <view class="filter-list filter-tabs">
      <view class="tab-item {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
      <view class="tab-item {{activeTab === 'pending' ? 'tab-active' : ''}}" data-tab="pending" bindtap="switchTab">审核中</view>
      <view class="tab-item {{activeTab === 'published' ? 'tab-active' : ''}}" data-tab="published" bindtap="switchTab">展示中</view>
      <view class="tab-item {{activeTab === 'rejected' ? 'tab-active' : ''}}" data-tab="rejected" bindtap="switchTab">未通过</view>
      <view class="tab-item {{activeTab === 'resolved' ? 'tab-active' : ''}}" data-tab="resolved" bindtap="switchTab">已完成</view>
      <view class="tab-item {{activeTab === 'closed' ? 'tab-active' : ''}}" data-tab="closed" bindtap="switchTab">已关闭</view>
    </view>
  </scroll-view>

  <view class="card post-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
    <view class="between post-head">
      <view class="post-title">{{item.title}}</view>
      <view class="post-head-right">
        <view class="audit-badge audit-{{item.auditTone}}">{{item.auditText}}</view>
        <view class="tag {{item.type === 'found' ? 'tag-green' : 'tag-orange'}}">{{item.type === 'found' ? '招领' : '寻物'}}</view>
      </view>
    </view>

    <view class="post-meta">
      <text>{{item.category}}</text>
      <text class="dot">·</text>
      <text>{{item.location}}</text>
      <text class="dot">·</text>
      <text>{{item.timeText}}</text>
    </view>

    <view class="post-desc">{{item.description || '无'}}</view>

    <view wx:if="{{item.showRejectReason}}" class="audit-tip">
      <view class="audit-tip-title">失败原因</view>
      <view class="audit-tip-text">{{item.auditReasonText}}</view>
    </view>

    <view class="status-info-row">
      <view class="status status-{{item.statusTone}}">{{item.statusText}}</view>
      <view class="status-desc">{{item.statusDesc}}</view>
    </view>

    <view class="image-grid" wx:if="{{item.images && item.images.length}}">
      <image class="my-image" wx:for="{{item.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
    </view>

    <view class="between mt-20 action-row">
      <view class="text-muted">{{item.createdAtText || item.createdAt}}</view>
      <view class="detail-entry">查看详情</view>
    </view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty-wrap">
    <image class="empty-placeholder" src="/images/icon-empty-placeholder.svg" mode="aspectFit" />
    <view class="empty-text">{{emptyTitle}}</view>
    <view class="empty-subtext">{{emptyDesc}}</view>
  </view>
</view>
</view>
