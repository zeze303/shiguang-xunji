.my-posts-page {
  padding-bottom: 32rpx;
}

.my-posts-hero {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.my-posts-hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.24em;
  color: var(--text-dim);
}

.my-posts-hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.my-posts-hero-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.8;
}

.search-box {
  width: 100%;
  margin-bottom: 16rpx;
}

.list-search-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: var(--glass);
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  color: var(--text-primary);
}

.list-placeholder {
  color: var(--text-dim);
  font-size: 28rpx;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-list {
  display: inline-flex;
}

.filter-tabs {
  gap: 12rpx;
}

.tab-item {
  min-width: 128rpx;
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: var(--text-dim);
  font-size: 26rpx;
  font-weight: 400;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-sizing: border-box;
}

.tab-active {
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  font-weight: 600;
  border-color: transparent;
}

.post-card {
  margin-bottom: 20rpx;
}

.post-head {
  align-items: flex-start;
}

.post-head-right {
  display: flex;
  align-items: center;
}

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.5;
}

.audit-badge {
  margin-right: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.audit-success {
  background: #dcfce7;
  color: #15803d;
}

.audit-danger {
  background: #fee2e2;
  color: #b91c1c;
}

.audit-warning {
  background: #fff7ed;
  color: #c2410c;
}

.post-meta {
  margin-top: 16rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.6;
}

.dot {
  margin: 0 10rpx;
}

.post-desc {
  margin-top: 14rpx;
  color: var(--text-primary);
  opacity: 0.88;
  font-size: 26rpx;
  line-height: 1.7;
}

.audit-tip {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.audit-tip-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #b91c1c;
}

.audit-tip-text {
  margin-top: 8rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
}

.status-info-row {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--glass-border);
}

.status {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-warning {
  background: rgba(217, 119, 6, 0.12);
  color: var(--amber);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
}

.status-success {
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.status-default {
  background: var(--surface-muted);
  color: var(--text-dim);
  border: 1rpx solid var(--glass-border);
}

.status-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180rpx, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.my-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20rpx;
  background: var(--surface-muted);
  border: 1rpx solid var(--glass-border);
}

.action-row {
  align-items: center;
}

.detail-entry {
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
}

.empty-wrap {
  padding: 100rpx 0;
  text-align: center;
}

.empty-placeholder {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 14rpx;
}

.empty-text {
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 600;
}

.empty-subtext {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.85;
}
