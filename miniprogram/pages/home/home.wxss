.hero-theme-row {
  position: absolute;
  top: 64rpx;
  right: 20rpx;
  z-index: 3;
  display: flex;
  justify-content: flex-end;
}

.hero-theme-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  min-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.14);
}

.page-root.theme-dark .hero-theme-chip {
  background: rgba(15, 23, 42, 0.24);
  border-color: rgba(255, 255, 255, 0.16);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.24);
}

.home-page {
  position: relative;
  z-index: 2;
  padding-bottom: 150rpx;
}

.container.page-top-safe.home-page {
  padding-top: calc(env(safe-area-inset-top) + 12rpx);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 0;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, rgba(8, 145, 178, 0.92) 0%, rgba(59, 130, 246, 0.88) 48%, rgba(99, 102, 241, 0.9) 100%);
  box-shadow: 0 20rpx 56rpx rgba(8, 145, 178, 0.28);
}

.page-root.theme-dark .hero-card {
  background: linear-gradient(135deg, rgba(14, 116, 144, 0.95) 0%, rgba(79, 70, 229, 0.85) 55%, rgba(126, 34, 206, 0.78) 100%);
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.45);
}

.hero-aurora {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  opacity: 0.42;
  filter: blur(48rpx);
}

.hero-blob-1 {
  width: 280rpx;
  height: 280rpx;
  left: -80rpx;
  top: -60rpx;
  background: var(--blob-1);
  animation: hero-drift-a 16s ease-in-out infinite;
}

.hero-blob-2 {
  width: 240rpx;
  height: 240rpx;
  right: -70rpx;
  top: 40%;
  background: var(--blob-2);
  animation: hero-drift-b 19s ease-in-out infinite;
}

.hero-blob-3 {
  width: 200rpx;
  height: 200rpx;
  left: 30%;
  bottom: -50rpx;
  background: var(--blob-3);
  animation: hero-drift-c 22s ease-in-out infinite;
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.14;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.35) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.35) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
}

.hero-shimmer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.hero-shimmer::after {
  content: "";
  position: absolute;
  top: -40%;
  left: -60%;
  width: 55%;
  height: 220%;
  background: linear-gradient(115deg, transparent 0%, rgba(255, 255, 255, 0.22) 45%, transparent 78%);
  animation: hero-sweep 5s ease-in-out infinite;
}

.hero-inner {
  position: relative;
  z-index: 2;
  padding: 22rpx 28rpx 32rpx;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.28em;
  color: rgba(255, 255, 255, 0.68);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, var(--hero-title-from) 0%, var(--hero-title-to) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.92);
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.78);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex: 1 1 200rpx;
  min-height: 84rpx;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
}

.hero-btn-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.hero-btn-label {
  font-size: var(--font-sm);
  font-weight: 600;
}

.hero-btn-primary {
  background: #ffffff;
  color: #0f172a;
}

.hero-btn-primary .hero-btn-icon {
  filter: brightness(0.3);
}

.hero-btn-accent {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  backdrop-filter: blur(12px);
  border-color: rgba(255, 255, 255, 0.35);
}

.hero-btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(12px);
  flex: 0 1 auto;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(132rpx, 1fr));
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

.stats-item {
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.stats-icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
  margin: 0 auto 6rpx;
}

.stats-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #ffffff;
}

.stats-label {
  margin-top: var(--spacing-xs);
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.88);
}

@keyframes hero-drift-a {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(24rpx, -16rpx) scale(1.08);
  }
}

@keyframes hero-drift-b {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(-30rpx, 20rpx) scale(1.05);
  }
}

@keyframes hero-drift-c {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(16rpx, 24rpx) scale(0.96);
  }
}

@keyframes hero-sweep {
  0% {
    transform: translateX(-20%) rotate(12deg);
  }
  100% {
    transform: translateX(220%) rotate(12deg);
  }
}



.section-block {
  margin-top: 28rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-dim);
}

.section-link {
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
}

.quick-chip-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.quick-chip-list {
  display: inline-flex;
  padding-bottom: 4rpx;
}

.quick-chip {
  padding: 14rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--glass-border);
  background: var(--glass);
  color: var(--text-dim);
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.quick-chip-active {
  color: var(--cyan);
  border-color: rgba(8, 145, 178, 0.35);
  background: rgba(8, 145, 178, 0.12);
}

.page-root.theme-dark .quick-chip-active {
  border-color: rgba(34, 211, 238, 0.35);
  background: rgba(34, 211, 238, 0.12);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280rpx, 1fr));
  gap: 16rpx;
}

.quick-card {
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
}

.quick-card-active {
  border-color: rgba(8, 145, 178, 0.32);
  box-shadow: 0 16rpx 40rpx rgba(8, 145, 178, 0.16);
}

.page-root.theme-dark .quick-card-active {
  border-color: rgba(34, 211, 238, 0.32);
  box-shadow: 0 16rpx 40rpx rgba(34, 211, 238, 0.12);
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.quick-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.7;
}

.latest-card {
  position: relative;
  display: flex;
  align-items: stretch;
  flex-wrap: nowrap;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
}

.latest-rail {
  width: 6rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.latest-rail-found {
  background: linear-gradient(180deg, var(--mint), var(--cyan));
}

.latest-rail-lost {
  background: linear-gradient(180deg, var(--amber), #f97316);
}

.latest-main {
  flex: 1;
  min-width: 0;
}

.latest-head {
  align-items: flex-start;
}

.latest-title {
  flex: 1;
  margin-right: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
}

.latest-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-dim);
}

.latest-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: var(--text-primary);
  opacity: 0.92;
  line-height: 1.8;
}

.latest-foot {
  margin-top: 18rpx;
  align-items: center;
}

.latest-visual {
  width: clamp(88rpx, 20vw, 120rpx);
  align-self: stretch;
  min-height: 132rpx;
  border-radius: 20rpx;
  flex: 0 0 auto;
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, rgba(8, 145, 178, 0.12), rgba(99, 102, 241, 0.18));
  border: 1rpx solid rgba(8, 145, 178, 0.18);
}

.page-root.theme-dark .latest-visual {
  background: linear-gradient(145deg, rgba(34, 211, 238, 0.14), rgba(99, 102, 241, 0.22));
  border-color: rgba(34, 211, 238, 0.18);
}

.latest-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-warning {
  background: rgba(217, 119, 6, 0.12);
  color: var(--amber);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
}

.status-success {
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.status-default {
  background: var(--surface-muted);
  color: var(--text-dim);
  border: 1rpx solid var(--glass-border);
}

.empty-lite {
  padding: 48rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--glass);
  border: 2rpx dashed rgba(148, 163, 184, 0.35);
  text-align: center;
}

.empty-lite-title {
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 600;
}

.empty-lite-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.85;
}
