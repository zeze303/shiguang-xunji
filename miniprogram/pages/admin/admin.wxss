.admin-page {
  padding-bottom: 32rpx;
}

.admin-hero {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.admin-hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.24em;
  color: var(--text-dim);
}

.admin-hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.admin-hero-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.8;
}

.search-box {
  width: 100%;
  margin-bottom: 16rpx;
}

.list-search-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  background: var(--glass);
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border);
  box-sizing: border-box;
  color: var(--text-primary);
}

.list-placeholder {
  color: var(--text-dim);
  font-size: 28rpx;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-list {
  display: inline-flex;
}

.filter-tabs {
  gap: 12rpx;
}

.tab-item {
  min-width: 128rpx;
  text-align: center;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: var(--text-dim);
  font-size: 26rpx;
  font-weight: 400;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-sizing: border-box;
}

.tab-active {
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  font-weight: 600;
  border-color: transparent;
}

.post-card {
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.post-card[data-audit="pending"]::before {
  background: var(--color-warning);
}

.post-card[data-audit="approved"]::before {
  background: var(--color-success);
}

.post-card[data-audit="rejected"]::before {
  background: var(--color-error);
}

.post-card[data-audit="closed"]::before,
.post-card[data-audit="all"]::before {
  background: var(--text-dim);
}

.post-head-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.admin-thumb {
  width: 80rpx;
  height: 80rpx;
  flex: 0 0 80rpx;
  border-radius: 14rpx;
  background: var(--surface-muted);
  border: 1rpx solid var(--glass-border);
}

.post-head-main {
  flex: 1;
  min-width: 0;
}

.post-head-right {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.5;
}

.post-meta {
  margin-top: 16rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.6;
}

.openid-row {
  margin-top: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: var(--input-bg);
  border: 1rpx dashed var(--glass-border);
  color: var(--text-primary);
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-all;
}

.dot {
  margin: 0 10rpx;
}

.audit-badge {
  margin-right: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.audit-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.audit-danger {
  background: var(--color-error-bg);
  color: var(--color-error);
}

.audit-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.status {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-warning {
  background: rgba(217, 119, 6, 0.12);
  color: var(--amber);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
}

.status-success {
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.status-default {
  background: var(--surface-muted);
  color: var(--text-dim);
  border: 1rpx solid var(--glass-border);
}

.status-time {
  color: var(--text-dim);
  font-size: 24rpx;
}

.audit-panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--glass-border);
}

.audit-panel-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.audit-remark {
  margin-top: 8rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
}

.admin-action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.approve-btn,
.reject-btn,
.delete-btn {
  margin: 0;
  flex: 1 1 160rpx;
  min-width: 0;
  padding: 0 18rpx;
  min-height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.approve-btn {
  color: #fff;
  background: var(--color-success);
}

.approve-btn:active {
  background: var(--color-success-hover);
}

.reject-btn {
  color: var(--color-warning);
  background: transparent;
  border: 1.5rpx solid var(--color-warning);
}

.reject-btn:active {
  background: var(--color-warning-bg);
}

.delete-btn {
  color: var(--color-error);
  background: transparent;
  border: 1.5rpx solid var(--color-error);
}

.delete-btn:active {
  background: var(--color-error-bg);
}

.approve-btn::after,
.reject-btn::after,
.delete-btn::after {
  border: none;
}

.detail-entry {
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
}

.empty-wrap {
  padding: 100rpx 0;
  text-align: center;
}

.empty-placeholder {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 14rpx;
}

.empty-text {
  color: var(--text-dim);
  font-size: 28rpx;
  font-weight: 600;
}

.empty-subtext {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.85;
}
