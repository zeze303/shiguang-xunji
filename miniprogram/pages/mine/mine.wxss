.mine-page {
  padding-bottom: 32rpx;
}

.mine-hero {
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.mine-hero-kicker {
  font-size: 20rpx;
  letter-spacing: 0.24em;
  color: var(--text-dim);
}

.mine-hero-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.mine-hero-desc {
  margin-top: 10rpx;
  color: var(--text-dim);
  font-size: 24rpx;
  line-height: 1.8;
}

.profile-card {
  padding: 28rpx;
  border-radius: var(--radius-lg);
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
}

.profile-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 22rpx;
}

.avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  margin-right: 0;
  margin-bottom: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(8, 145, 178, 0.15);
  border: 1rpx solid rgba(8, 145, 178, 0.35);
}

.page-root.theme-dark .avatar {
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.35);
}

.avatar-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cyan);
  font-size: 40rpx;
  font-weight: 700;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.7;
}

.openid-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: var(--input-bg);
  border: 1rpx solid var(--input-border);
}

.openid-label {
  font-size: 22rpx;
  color: var(--text-dim);
}

.openid-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--cyan);
  line-height: 1.7;
  word-break: break-all;
}

.profile-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.profile-btn {
  flex: 1 1 240rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(8, 145, 178, 0.12);
  color: var(--cyan);
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(8, 145, 178, 0.28);
  box-sizing: border-box;
}

.page-root.theme-dark .profile-btn {
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.35);
}

.profile-btn-light {
  background: var(--surface-muted);
  color: var(--text-dim);
  border: 1rpx solid var(--glass-border);
}

.menu-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: var(--radius-lg);
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
}

.admin-card {
  border-color: rgba(8, 145, 178, 0.35);
}

.page-root.theme-dark .admin-card {
  border-color: rgba(34, 211, 238, 0.35);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--glass-border);
}

.menu-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  opacity: 0.92;
}

.menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.menu-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  line-height: 1.7;
}

.menu-arrow {
  color: var(--text-dim);
  font-size: 34rpx;
  font-weight: 400;
}
