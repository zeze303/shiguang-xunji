/**
 * 主题由页面根节点 .page-root.theme-light | .theme-dark 控制（应用内切换 + 跟随系统）。
 * 自定义 TabBar 根节点同时使用 .theme-root + .theme-light|.theme-dark。
 */
.page-root.theme-light,
.theme-root.theme-light {
  --void: #e4eaf4;
  --glass: rgba(255, 255, 255, 0.42);
  --glass-border: rgba(255, 255, 255, 0.3);
  --cyan: #0891b2;
  --cyan-soft: #22d3ee;
  --violet: #7c3aed;
  --amber: #d97706;
  --mint: #059669;
  --text-primary: #0f172a;
  --text-dim: #64748b;
  --hero-title-from: #ffffff;
  --hero-title-to: rgba(255, 255, 255, 0.82);
  --surface-solid: rgba(255, 255, 255, 0.6);
  --surface-muted: rgba(255, 255, 255, 0.34);
  --input-bg: rgba(248, 250, 252, 0.54);
  --input-border: rgba(255, 255, 255, 0.24);
  --shadow-card: 0 18rpx 46rpx rgba(76, 108, 152, 0.12);
  --shadow-strong: 0 22rpx 56rpx rgba(76, 108, 152, 0.15);

  /* 语义色 */
  --color-success: #10B981;
  --color-success-bg: rgba(16, 185, 129, 0.12);
  --color-success-hover: #059669;
  --color-warning: #F59E0B;
  --color-warning-bg: rgba(245, 158, 11, 0.12);
  --color-warning-hover: #D97706;
  --color-error: #EF4444;
  --color-error-bg: rgba(239, 68, 68, 0.12);
  --color-error-hover: #DC2626;
  --color-info: #3B82F6;
  --color-info-bg: rgba(59, 130, 246, 0.12);
  --color-info-hover: #2563EB;

  /* 间距体系 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字号体系 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 26rpx;
  --font-lg: 30rpx;
  --font-xl: 34rpx;

  /* 圆角扩展 */
  --radius-xs: 8rpx;
  --radius-xl: 32rpx;

  --blob-1: rgba(6, 182, 212, 0.45);
  --blob-2: rgba(99, 102, 241, 0.38);
  --blob-3: rgba(217, 70, 239, 0.28);
  --bg-gradient-main: linear-gradient(180deg, #eef7ff 0%, #e8f0ff 42%, #dde8fb 100%);
  --bg-glow-top: radial-gradient(circle at 16% 10%, rgba(34, 211, 238, 0.28), transparent 30%);
  --bg-glow-mid: radial-gradient(circle at 52% 46%, rgba(14, 165, 233, 0.16), transparent 26%);
  --bg-glow-bottom: radial-gradient(circle at 84% 88%, rgba(124, 58, 237, 0.2), transparent 28%);
  --bg-grid-line: rgba(148, 163, 184, 0.08);
  --bg-noise: rgba(255, 255, 255, 0.08);
}

.page-root.theme-dark,
.theme-root.theme-dark {
  --void: #030712;
  --glass: rgba(255, 255, 255, 0.06);
  --glass-border: rgba(255, 255, 255, 0.12);
  --cyan: #22d3ee;
  --cyan-soft: #67e8f9;
  --violet: #a78bfa;
  --amber: #fbbf24;
  --mint: #34d399;
  --text-primary: #f8fafc;
  --text-dim: #94a3b8;
  --hero-title-from: #ffffff;
  --hero-title-to: rgba(248, 250, 252, 0.88);
  --surface-solid: rgba(15, 23, 42, 0.72);
  --surface-muted: rgba(255, 255, 255, 0.06);
  --input-bg: rgba(15, 23, 42, 0.5);
  --input-border: rgba(255, 255, 255, 0.12);
  --shadow-card: 0 12rpx 48rpx rgba(0, 0, 0, 0.35);
  --shadow-strong: 0 20rpx 56rpx rgba(0, 0, 0, 0.45);

  /* 语义色 */
  --color-success: #34D399;
  --color-success-bg: rgba(52, 211, 153, 0.15);
  --color-success-hover: #10B981;
  --color-warning: #FBBF24;
  --color-warning-bg: rgba(251, 191, 36, 0.15);
  --color-warning-hover: #F59E0B;
  --color-error: #F87171;
  --color-error-bg: rgba(248, 113, 113, 0.15);
  --color-error-hover: #EF4444;
  --color-info: #60A5FA;
  --color-info-bg: rgba(96, 165, 250, 0.15);
  --color-info-hover: #3B82F6;

  /* 间距体系 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字号体系 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 26rpx;
  --font-lg: 30rpx;
  --font-xl: 34rpx;

  /* 圆角扩展 */
  --radius-xs: 8rpx;
  --radius-xl: 32rpx;

  --blob-1: rgba(34, 211, 238, 0.35);
  --blob-2: rgba(99, 102, 241, 0.32);
  --blob-3: rgba(232, 121, 249, 0.28);
  --bg-gradient-main: linear-gradient(180deg, #03101d 0%, #040d1f 38%, #020712 100%);
  --bg-glow-top: radial-gradient(circle at 14% 12%, rgba(34, 211, 238, 0.26), transparent 32%);
  --bg-glow-mid: radial-gradient(circle at 52% 48%, rgba(59, 130, 246, 0.16), transparent 28%);
  --bg-glow-bottom: radial-gradient(circle at 84% 82%, rgba(167, 139, 250, 0.2), transparent 30%);
  --bg-grid-line: rgba(148, 163, 184, 0.06);
  --bg-noise: rgba(255, 255, 255, 0.03);
}
