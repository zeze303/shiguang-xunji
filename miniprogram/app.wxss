@import "./styles/theme-tokens.wxss";
@import "./styles/icon-placeholder.wxss";

page {
  background-color: #e4eaf4;
  font-size: 28rpx;
  box-sizing: border-box;
}

.page-root {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg-gradient-main);
  background-attachment: fixed;
  color: var(--text-primary);
  overflow: hidden;
}

.page-root::before,
.page-root::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.page-root::before {
  background:
    var(--bg-glow-top),
    var(--bg-glow-mid),
    var(--bg-glow-bottom);
  background-size: 100% 100%, 100% 140%, 100% 100%;
  background-position: center top, center center, center bottom;
  animation: background-drift 22s ease-in-out infinite alternate;
  opacity: 0.96;
  z-index: 0;
}

.page-root::after {
  background-image:
    linear-gradient(var(--bg-grid-line) 1rpx, transparent 1rpx),
    linear-gradient(90deg, var(--bg-grid-line) 1rpx, transparent 1rpx),
    radial-gradient(circle at center, var(--bg-noise) 0, transparent 58%);
  background-size: 44rpx 44rpx, 44rpx 44rpx, 100% 100%;
  background-position: center, center, center;
  animation: grid-float 18s linear infinite;
  opacity: 0.72;
  z-index: 0;
}

@keyframes background-drift {
  0% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  100% {
    transform: translate3d(0, -36rpx, 0) scale(1.04);
  }
}

/* --- 过渡动效（G05） --- */

@keyframes slide-up {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slide-down {
  from { opacity: 0; transform: translateY(-24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes scale-in {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}

@keyframes grid-float {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(0, -44rpx, 0);
  }
}


.container {
  position: relative;
  z-index: 1;
  padding: 24rpx 24rpx 252rpx;
  box-sizing: border-box;
}

.page-top-safe {
  position: relative;
  z-index: 1;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

.card {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 100%;
  background: var(--glass);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--glass-border);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  overflow: hidden;
}

/* backdrop-filter fallback：不支持 blur 的机型有底色 */
@supports not (backdrop-filter: blur(1px)) {
  .theme-dark .card {
    background: rgba(15, 23, 42, 0.78);
  }
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 600;
  margin-bottom: 18rpx;
  color: var(--text-primary);
}

.text-muted {
  color: var(--text-dim);
}

.primary-btn {
  background: linear-gradient(90deg, var(--cyan-soft), var(--cyan));
  color: #030712;
  border-radius: 12rpx;
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: 0 8rpx 28rpx rgba(8, 145, 178, 0.22);
}

.page-root.theme-dark .primary-btn {
  box-shadow: 0 8rpx 32rpx rgba(34, 211, 238, 0.28);
}

.success-btn {
  background: var(--mint);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: var(--font-md);
  font-weight: 600;
}

.danger-btn {
  background: #ef4444;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: var(--font-md);
  font-weight: 600;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7rpx 14rpx;
  border-radius: 12rpx;
  font-size: var(--font-xs);
  margin-right: 10rpx;
  font-weight: 600;
}

.tag-blue {
  background: rgba(8, 145, 178, 0.12);
  color: var(--cyan);
  border: 1rpx solid rgba(8, 145, 178, 0.28);
}

.page-root.theme-dark .tag-blue {
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.35);
}

.tag-green {
  background: rgba(5, 150, 105, 0.12);
  color: var(--mint);
  border: 1rpx solid rgba(52, 211, 153, 0.35);
}

.page-root.theme-dark .tag-green {
  background: rgba(52, 211, 153, 0.12);
}

.tag-orange {
  background: rgba(217, 119, 6, 0.12);
  color: var(--amber);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
}

.page-root.theme-dark .tag-orange {
  background: rgba(251, 191, 36, 0.1);
}

.input {
  width: 100%;
  background: var(--input-bg);
  border: 2rpx solid var(--input-border);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  color: var(--text-primary);
}

.textarea {
  min-height: 220rpx;
}

.flex {
  display: flex;
}

.between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}
